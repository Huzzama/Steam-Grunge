# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environment ───────────────────────────────────────────────────────
venv/
.venv/
env/
.env/

# ── Exports (user-generated artwork — not source code) ────────────────────────
exports/

# ── User data (cache, presets, preferences) ───────────────────────────────────
data/cache/
data/presets/
data/steam_path_override.json
data/preferences.json
data/api_key.json

# ── Packaging build artifacts (keep scripts, ignore output files) ──────────────
packaging/appimage/*.AppImage
packaging/appimage/appimagetool.AppImage
packaging/appimage/*.AppDir/
packaging/debian/steam-grunge-editor_*/
packaging/debian/*.deb
packaging/arch/pkg/
packaging/arch/src/
packaging/arch/*.pkg.tar.zst
packaging/arch/*.pkg.tar.xz

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini

# ── IDE / editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ── API keys / secrets ────────────────────────────────────────────────────────
*.key
secrets.json
.env

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log

# ── Windows build artifacts ───────────────────────────────────────────────────
dist/
build/
packaging/windows/__pycache__/
app/assets/icon.ico      # auto-generated during build, not source
*.spec.bak