# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environment ───────────────────────────────────────────────────────
venv/
.venv/
env/
.env/

# ── Exports (user-generated artwork — not source code) ────────────────────────
exports/

# ── User data (cache, presets, preferences) ───────────────────────────────────
data/cache/
data/presets/
data/steam_path_override.json
data/preferences.json
data/api_key.json

# ── Packaging build artifacts (keep scripts, ignore output files) ──────────────
packaging/appimage/*.AppImage
packaging/appimage/appimagetool.AppImage
packaging/appimage/*.AppDir/
packaging/debian/steam-grunge-editor_*/
packaging/debian/*.deb
packaging/arch/pkg/
packaging/arch/src/
packaging/arch/*.pkg.tar.zst
packaging/arch/*.pkg.tar.xz

# ── macOS build artifacts ─────────────────────────────────────────────────────
packaging/macos/dist/
packaging/macos/build/
packaging/macos/icon.iconset/
packaging/macos/*.dmg
app/assets/icon.icns

# ── Windows build artifacts ───────────────────────────────────────────────────
packaging/windows/Output/
packaging/windows/dist/
packaging/windows/build/

# ── Screenshots (keep folder, ignore OS junk inside) ──────────────────────────
docs/screenshots/.DS_Store

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini

# ── IDE / editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ── API keys / secrets ────────────────────────────────────────────────────────
*.key
secrets.json
.env

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log

# ── Nested repo (Steam-Grunge subfolder if cloned inside project) ─────────────
Steam-Grunge/